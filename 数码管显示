#include<reg51.h>

sbit dula=P2^6;
sbit wela=P2^7;
void delay(unsigned int z);
void main()
{
    while(1)
    {
        wela=1;
        P0=0xfd;
        wela=0;

        dula=1;
        P0=0x06;
        dula=0;
        delay(5);
    }
}

void delay(unsigned int z)
{
    unsigned int i,j;
    for(i=z;i>0;i--)
        for(j=110;j>0;j--);
}
