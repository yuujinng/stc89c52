/***********************************************************
* 文件：通用三位数码管动态扫描程序
* 功能：可显示任意3位数字，支持0~9数字和部分字符
* 硬件：P2.6=段选锁存(dula)，P2.7=位选锁存(wela)
* 使用：修改display_buffer数组即可改变显示内容
***********************************************************/

#include<reg51.h>

// 引脚定义
sbit dula = P2^6;  // 段选锁存
sbit wela = P2^7;  // 位选锁存

// 函数声明
void delay_ms(unsigned int ms);
void display_digit(unsigned char pos, unsigned char num);
void display_all(void);
void clear_display(void);

// ====================== 配置区 ======================
// 1. 定义要显示的3位数字（0-9，10=显示'-'，11=熄灭）
unsigned char display_buffer[3] = {1, 2, 3};  // 默认显示"123"

// 2. 数码管类型选择（根据你的硬件修改）
#define COMMON_CATHODE  1  // 共阴极数码管
// #define COMMON_ANODE   1  // 共阳极数码管

// 3. 位选码定义（根据硬件接线修改）
unsigned char code BIT_SELECT[3] = {0xfe, 0xfd, 0xfb};  // 个、十、百位
// 如果显示顺序不对，可以调整这个数组：
// {0xfb, 0xfd, 0xfe}  // 百、十、个位
// ===================================================

// 共阴极段码表（0-9, 10='-', 11=熄灭）
#ifdef COMMON_CATHODE
unsigned char code SEG_CODE[] = {
    0x3f,  // 0: 00111111
    0x06,  // 1: 00000110
    0x5b,  // 2: 01011011
    0x4f,  // 3: 01001111
    0x66,  // 4: 01100110
    0x6d,  // 5: 01101101
    0x7d,  // 6: 01111101
    0x07,  // 7: 00000111
    0x7f,  // 8: 01111111
    0x6f,  // 9: 01101111
    0x40,  // 10: '-' 横杠
    0x00   // 11: 全部熄灭
};
#endif

// 共阳极段码表（如果使用共阳极数码管）
#ifdef COMMON_ANODE
unsigned char code SEG_CODE[] = {
    0xc0,  // 0: 11000000
    0xf9,  // 1: 11111001
    0xa4,  // 2: 10100100
    0xb0,  // 3: 10110000
    0x99,  // 4: 10011001
    0x92,  // 5: 10010010
    0x82,  // 6: 10000010
    0xf8,  // 7: 11111000
    0x80,  // 8: 10000000
    0x90,  // 9: 10010000
    0xbf,  // 10: '-' 横杠
    0xff   // 11: 全部熄灭
};
#endif

/***********************************************************
* 功能：毫秒级延时函数
* 参数：ms - 延时的毫秒数
***********************************************************/
void delay_ms(unsigned int ms)
{
    unsigned int i, j;
    for(i = ms; i > 0; i--)
        for(j = 114; j > 0; j--);
}

/***********************************************************
* 功能：显示单个数字到指定位置
* 参数：pos - 位置(0=个位,1=十位,2=百位)
*       num - 要显示的数字(0-11)
***********************************************************/
void display_digit(unsigned char pos, unsigned char num)
{
    if(pos > 2) return;  // 位置保护
    if(num > 11) num = 11;  // 数字保护
    
    // 1. 位选：选择要显示的位置
    wela = 1;
    P0 = BIT_SELECT[pos];
    wela = 0;
    P0 = 0xff;  // 关闭位选，防止干扰
    
    // 2. 段选：输出数字对应的段码
    dula = 1;
    P0 = SEG_CODE[num];
    dula = 0;
    
    // 3. 短暂延时，保持显示
    delay_ms(2);
    
    // 4. 消隐（防止残影）
    dula = 1;
    P0 = 0x00;
    dula = 0;
}

/***********************************************************
* 功能：刷新显示整个3位数
* 说明：在while(1)中循环调用此函数
***********************************************************/
void display_all(void)
{
    unsigned char i;
    
    for(i = 0; i < 3; i++)
    {
        display_digit(i, display_buffer[i]);
    }
}

/***********************************************************
* 功能：清空数码管显示
***********************************************************/
void clear_display(void)
{
    unsigned char i;
    
    for(i = 0; i < 3; i++)
    {
        wela = 1;
        P0 = BIT_SELECT[i];
        wela = 0;
        
        dula = 1;
        P0 = 0x00;  // 所有段都熄灭
        dula = 0;
    }
}

/***********************************************************
* 功能：设置要显示的三位数
* 参数：num1 - 百位数(0-11)
*       num2 - 十位数(0-11) 
*       num3 - 个位数(0-11)
***********************************************************/
void set_display(unsigned char num1, unsigned char num2, unsigned char num3)
{
    display_buffer[2] = num1;  // 百位
    display_buffer[1] = num2;  // 十位
    display_buffer[0] = num3;  // 个位
}

/***********************************************************
* 功能：显示一个整数（0-999）
* 参数：value - 要显示的整数
***********************************************************/
void display_number(unsigned int value)
{
    if(value > 999) value = 999;  // 限制在3位数内
    
    // 分离百位、十位、个位
    display_buffer[2] = value / 100;           // 百位
    display_buffer[1] = (value % 100) / 10;   // 十位
    display_buffer[0] = value % 10;           // 个位
}

/***********************************************************
* 主函数
***********************************************************/
void main(void)
{
    unsigned int count = 0;  // 示例：计数器
    
    // 初始化
    clear_display();
    
    // 示例1：直接设置显示"888"
    display_buffer[0] = 8;  // 个位
    display_buffer[1] = 8;  // 十位
    display_buffer[2] = 8;  // 百位
    
    while(1)
    {
        // 方法1：直接刷新显示
        display_all();
        
        // 方法2：使用函数设置显示内容
        // display_number(count);  // 显示0-999的计数
        // count++;
        // if(count > 999) count = 0;
        
