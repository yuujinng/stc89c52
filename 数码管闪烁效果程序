/***********************************************************
* 数码管闪烁效果程序
* 功能：6位数码管显示从000000到FFFFFF的循环闪烁效果
* 硬件：P2.6=段选锁存(dula)，P2.7=位选锁存(wela)
* 效果：000000 -> 111111 -> 222222 -> ... -> FFFFFF -> 循环
***********************************************************/

#include<reg51.h>

// 引脚定义
sbit dula = P2^6;  // 段选锁存
sbit wela = P2^7;  // 位选锁存

// 全局变量
unsigned char display_buf[6];  // 显示缓冲区
unsigned char current_number = 0;  // 当前显示的数字(0-15)
unsigned int flash_counter = 0;    // 闪烁计数器
unsigned int display_delay = 0;    // 显示延时计数器

// 位选数组（6位数码管，从左到右）
unsigned char bit_sel[6] = {0xdf, 0xef, 0xf7, 0xfb, 0xfd, 0xfe};
// 第1位(左) 到 第6位(右)

// 扩展段码表（0-9, A-F, 16=熄灭）
unsigned char seg_code[17] = {
    0x3f,  // 0: 00111111
    0x06,  // 1: 00000110
    0x5b,  // 2: 01011011
    0x4f,  // 3: 01001111
    0x66,  // 4: 01100110
    0x6d,  // 5: 01101101
    0x7d,  // 6: 01111101
    0x07,  // 7: 00000111
    0x7f,  // 8: 01111111
    0x6f,  // 9: 01101111
    0x77,  // A: 01110111
    0x7c,  // b: 01111100
    0x39,  // C: 00111001
    0x5e,  // d: 01011110
    0x79,  // E: 01111001
    0x71,  // F: 01110001
    0x00   // 熄灭
};

/***********************************************************
* 功能：短延时函数
* 参数：t - 延时计数值
***********************************************************/
void delay(unsigned int t)
{
    while(t--);
}

/***********************************************************
* 功能：显示单个数字到指定位置
* 参数：pos - 位置(0-5，0=最左边，5=最右边)
*       num - 要显示的数字(0-16)
***********************************************************/
void display_digit(unsigned char pos, unsigned char num)
{
    if(pos > 5) return;
    if(num > 16) num = 16;
    
    // 1. 位选：选择要显示的位置
    wela = 1;
    P0 = bit_sel[pos];
    wela = 0;
    
    // 2. 段选：输出数字对应的段码
    dula = 1;
    P0 = seg_code[num];
    dula = 0;
    
    // 3. 短暂延时
    delay(80);
    
    // 4. 消隐（防止残影）
    dula = 1;
    P0 = 0x00;
    dula = 0;
}

/***********************************************************
* 功能：刷新显示整个6位数
***********************************************************/
void display_all(void)
{
    unsigned char i;
    
    for(i = 0; i < 6; i++)
    {
        display_digit(i, display_buf[i]);
    }
}

/***********************************************************
* 功能：更新显示缓冲区
* 将所有6位设置为相同的数字
***********************************************************/
void update_display(void)
{
    unsigned char i;
    
    for(i = 0; i < 6; i++)
    {
        display_buf[i] = current_number;
    }
}

/***********************************************************
* 功能：定时器0中断服务函数
* 用于控制闪烁频率
***********************************************************/
void timer0_isr(void) interrupt 1
{
    TH0 = 0xFC;  // 重装初值，约1ms@12MHz
    TL0 = 0x18;
    
    flash_counter++;
    
    // 每500ms切换一次数字
    if(flash_counter >= 500)
    {
        flash_counter = 0;
        
        // 切换到下一个数字
        current_number++;
        if(current_number > 15)  // 超过F，回到0
        {
            current_number = 0;
        }
        
        // 更新显示
        update_display();
    }
}

/***********************************************************
* 功能：定时器初始化
***********************************************************/
void timer_init(void)
{
    TMOD = 0x01;        // 定时器0，工作方式1
    TH0 = 0xFC;         // 装入初值，1ms@12MHz
    TL0 = 0x18;
    EA = 1;             // 开总中断
    ET0 = 1;            // 开定时器0中断
    TR0 = 1;            // 启动定时器0
}

/***********************************************************
* 主函数
***********************************************************/
void main(void)
{
    // 初始化定时器
    timer_init();
    
    // 初始化显示为000000
    current_number = 0;
    update_display();
    
    while(1)
    {
        // 不断刷新显示
        display_all();
    }
}
